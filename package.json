{
  "name": "cartograph",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "cd packages/persistence-drizzle && drizzle-kit generate",
    "db:push": "cd packages/persistence-drizzle && drizzle-kit push",
    "db:studio": "cd packages/persistence-drizzle && drizzle-kit studio",
    "dev:api": "cd apps/core-api && npm run dev",
    "dev:worker": "cd apps/worker && npm run dev",
    "dev:admin": "cd apps/admin-bff && npm run dev",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "stripe": "^18.0.0",
    "zod": "^4.3.6"
  }
}
