{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts",
    "plugins/**/*.ts",
    "tests/**/*.ts"
  ]
}
