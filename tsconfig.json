{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "topics/**/*.ts",
    "modules/**/*.ts",
    "platform/**/*.ts",
    "vitest.config.ts",
    "vitest.modules.config.ts",
    "exercise.ts"
  ],
  "exclude": ["topics/**/*.test.ts"]
}
